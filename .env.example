# App
NODE_ENV=development
LOG_FILE_ENABLED=false
# RESTART_ON_UNHEALTHY=false

# Telegram (required)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
HL_FRESH_WALLET_CHAT_ID=-1001234567890
HL_WHALE_ACTIVITY_CHAT_ID=-1001234567891
HL_BIG_WHALE_CHAT_ID=-1001234567892
HL_TWAP_CHAT_ID=-1001234567893
HL_TRACK_CHAT_ID=-1001234567894
STAKE_CHAT_ID=-1001234567895
POLY_CHAT_ID=-1001234567896
OWNER_USER_ID=123456789

# Database / Cache
MONGODB_URI=mongodb://root:example@localhost:27017
DB_NAME=whale-tracker-bot
REDIS_MODE=standalone
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Hyperliquid thresholds
HL_MIN_NOTIONAL_USD=250000
HL_AGGREGATION_WINDOW_MS=86400000
HL_POS_CHANGE_ALERT_PERCENT=9
HL_POS_CHANGE_ALERT_USD=50000
HL_FRESH_WINDOW_MS=180000000
HL_FRESH_MIN_USD=200000
HL_FRESH_MAIN_COIN_MIN_USD=450000
HL_WHALE_MIN_USD=300000
HL_BIG_WHALE_MIN_USD=1000000
HL_TWAP_BTC_ETH_MIN_USD=1000000
HL_TWAP_OTHER_MIN_USD=300000

# Stake thresholds
STAKE_MIN_BET_USD=10000

# Polymarket thresholds
POLY_ALERT_THRESHOLD_USD=100000
POLY_SPORT_BET_ALERT_THRESHOLD_USD=500000
POLY_MAX_PRICE_FILTER=0.98
POLY_POS_CHANGE_ALERT_PERCENT=20
POLY_POS_CHANGE_ALERT_USD=9000

# Puppeteer / screenshots
HL_SCREENSHOT_ENABLED=true
STAKE_SCREENSHOT_ENABLED=true
POLY_SCREENSHOT_ENABLED=true
OI_SCREENSHOT_ENABLED=true
PUPPETEER_USER_DIR=
PUPPETEER_HEADLESS=true
PUPPETEER_CONCURRENT_CAPTURES=false
PUPPETEER_PROXIES_PATH=./resources/ports.txt
PUPPETEER_PROXIES=

# CoinGlass OI Anomaly Tracker
COINGLASS_API_KEY=YOUR_COINGLASS_API_KEY
COINGLASS_EXCHANGES=Gate,Bybit,Binance,OKX,Kraken
COINGLASS_REFRESH_INTERVAL_MS=3600000
OI_CHAT_ID=-1001234567897
OI_HL_CHAT_ID=-1001234567898

# OpenRouter (required)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_CLASSIFIER_PROMPT_TEMPLATE_PATH=./resources/trade_classifier_prompt.txt
OPENROUTER_FAST_MODEL=gpt-3.5-turbo
