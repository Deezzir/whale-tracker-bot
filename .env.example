# App
NODE_ENV=development
LOG_FILE_ENABLED=false

# Telegram (required)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=-1001234567890
HS_MAIN_TOPIC_ID=1
HS_OTHER_TOPIC_ID=2
STAKE_TOPIC_ID=3
TRACK_TOPIC_ID=4
POLY_TOPIC_ID=5
OWNER_USER_ID=123456789

# Database / Cache
MONGODB_URI=mongodb://root:example@localhost:27017
DB_NAME=whale-tracker-bot
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Hyperliquid thresholds
HS_MIN_NOTIONAL_USD=250000
HS_AGGREGATION_WINDOW_MS=86400000
HS_POS_CHANGE_ALERT_PERCENT=20
HS_POS_CHANGE_ALERT_USD=50000

# Stake thresholds
STAKE_MIN_BET_USD=10000

# Polymarket thresholds
POLY_ALERT_THRESHOLD_USD=100000
POLY_SPORT_BET_ALERT_THRESHOLD_USD=500000
POLY_RE_ALERT_THRESHOLD_PERCENT=20
POLY_MAX_PRICE_FILTER=0.98
POLY_POS_CHANGE_ALERT_PERCENT=20
POLY_POS_CHANGE_ALERT_USD=9000

# Puppeteer
PUPPETEER_SCREENSHOT_ENABLED=true
PUPPETEER_USER_DIR=
PUPPETEER_HEADLESS=true
PUPPETEER_PROXIES_PATH=./resources/ports.txt
PUPPETEER_PROXIES=

# OpenRouter (required)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_CLASSIFIER_PROMPT_TEMPLATE_PATH=./resources/trade_classifier_prompt.txt
OPENROUTER_FAST_MODEL=gpt-3.5-turbo
